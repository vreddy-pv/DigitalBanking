<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-create-kyc-documents-table" author="banking-team">
        <createTable tableName="kyc_documents">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="customer_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="document_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="document_reference" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(30)" defaultValue="PENDING"/>
            <column name="rejection_reason" type="VARCHAR(500)"/>
            <column name="submitted_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
            <column name="reviewed_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>
    </changeSet>

    <changeSet id="002-create-beneficiaries-table" author="banking-team">
        <createTable tableName="beneficiaries">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="owner_account_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="beneficiary_account_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="nickname" type="VARCHAR(100)"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>
        <addUniqueConstraint
            tableName="beneficiaries"
            columnNames="owner_account_id, beneficiary_account_id"
            constraintName="uq_beneficiaries_owner_beneficiary"/>
    </changeSet>

    <changeSet id="003-create-customer-preferences-table" author="banking-team">
        <createTable tableName="customer_preferences">
            <column name="customer_id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="notification_email" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="notification_sms" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="language" type="VARCHAR(10)" defaultValue="en"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>
    </changeSet>

    <changeSet id="004-create-indexes" author="banking-team">
        <createIndex indexName="idx_kyc_customer_id" tableName="kyc_documents">
            <column name="customer_id"/>
        </createIndex>
        <createIndex indexName="idx_beneficiaries_owner" tableName="beneficiaries">
            <column name="owner_account_id"/>
        </createIndex>
        <createIndex indexName="idx_beneficiaries_active" tableName="beneficiaries">
            <column name="active"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
