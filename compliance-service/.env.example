DATABASE_URL=postgresql://compliance_user:password@postgres:5432/compliance_db
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_QUEUE=transaction_events
SERVICE_PORT=8008
SERVICE_HOST=0.0.0.0
LOG_LEVEL=INFO
ENV=development

# AML Thresholds (override as needed)
HIGH_VALUE_THRESHOLD=50000
LARGE_WITHDRAWAL_THRESHOLD=25000
FREQUENT_TX_WINDOW_MINUTES=60
FREQUENT_TX_COUNT=5
RAPID_TX_WINDOW_MINUTES=10
RAPID_TX_COUNT=3
STRUCTURING_LOWER=40000
STRUCTURING_UPPER=49999
STRUCTURING_COUNT=3
